generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  EMPLOYEE
  ADMIN
}

enum HouseholdRelationship {
  SELF
  CHILD
  RELATIVE
}

enum HouseholdProfileType {
  MANAGER
  YOUNG
  SENIOR
  OTHER
}

enum SchoolLevel {
  PRIMARY
  COLLEGE
  LYCEE
  HIGHER_EDUCATION
  OTHER
}

enum ConsentType {
  SERVICE_ALERTS
  MOBILITY_NEWS
  PARTNER_OFFERS
}

enum SubscriptionProductType {
  NAVIGO_ANNUAL
  IMAGINE_R
  NAVIGO_JUNIOR
  NAVIGO_SENIOR
  AMETHYSTE
  TST
  UNKNOWN
}

enum ProductType {
  NAVIGO_ANNUAL
  IMAGINE_R_JUNIOR
  IMAGINE_R_SCHOOL
  IMAGINE_R_STUDENT
  NAVIGO_SENIOR
  AMETHYSTE
  NAVIGO_LIBERTE
  UNKNOWN
}

enum TargetProfile {
  CHILD
  YOUNG
  STUDENT
  SENIOR
  ADULT
  FAMILY
  SOLIDARITY
}

enum DocumentType {
  PHOTO
  SCHOOL_CERTIFICATE
  ID_DOCUMENT
  ADDRESS_PROOF
  SCHOLARSHIP_CERTIFICATE
  SITUATION_PROOF
  PAYMENT_METHOD
}

enum SubscriptionStatus {
  ACTIVE
  TO_RENEW
  RECOMMENDED
  PENDING_DOCUMENT
  BLOCKED
  LOST
  EXPIRED
}

enum SubscriptionRequestStatus {
  DRAFT
  WAITING_DOCUMENTS
  UNDER_REVIEW
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  PAYMENT_CANCELLED
  CONFIRMED
  ACTIVE
  BLOCKED
  REJECTED
  CANCELLED
  EXPIRED
}

enum SubscriptionRequestFlow {
  GENERIC
  IMAGINE_R
}

enum SubscriptionRequestAddressType {
  HOLDER
  PAYER
}

enum SubscriptionRenewalType {
  ANNUAL
  MONTHLY
}

enum SubscriptionRenewalStatus {
  ACTIVE
  DISABLED
  CANCELLED
  EXPIRED
}

enum SubscriptionDocumentStatus {
  MISSING
  READY
  UPLOADED
  UNDER_REVIEW
  VALIDATED
  REJECTED
}

enum NavigoPassSupportType {
  PHYSICAL
  DIGITAL
}

enum NavigoPassStatus {
  ACTIVE
  IN_PROGRESS
  DISABLED
}

enum ImagineRScholarshipStatus {
  YES
  NO
  UNKNOWN
}

enum ImagineRDeliveryMode {
  PAYER_HOME
}

enum FamilyNotificationType {
  RENEWAL
  OFFER_RECOMMENDATION
  SERVICE_INFO
  SUPPORT_UPDATE
}

enum FamilyNotificationSeverity {
  INFO
  WARNING
  SUCCESS
  DANGER
}

enum SupportCaseType {
  LOST_PASS
  FOUND_PASS
  DOCUMENT_REJECTED
  PAYMENT_BLOCKED
}

enum SupportCaseStatus {
  OPEN
  IN_PROGRESS
  TRANSFER_TO_PHONE_REQUESTED
  PASS_DEACTIVATION_REQUESTED
  PASS_FOUND_WAITING_PICKUP
  PASS_PICKED_UP
  DIGITAL_SUPPORT_CONFIRMED
  PHYSICAL_PASS_REACTIVATION_REQUESTED
  PHYSICAL_PASS_REACTIVATED
  RESOLVED
  CANCELLED_BY_USER
}

enum SupportCaseResolution {
  TRANSFER_TO_PHONE
  DEACTIVATE_ONLY
}

enum SupportCaseFinalChoice {
  DIGITAL_SUPPORT
  PHYSICAL_PASS_REACTIVATION
}

enum MemberDetailActionVariant {
  PRIMARY
  SECONDARY
  GHOST
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id            String      @id @default(uuid())
  firstName     String      @default("")
  lastName      String      @default("")
  email         String      @unique
  phone         String      @default("")
  passwordHash  String      @default("")
  authProvider  AuthProvider @default(LOCAL)
  providerId    String?
  avatarUrl     String?
  role          UserRole    @default(USER)
  phoneVerified Boolean     @default(false)
  emailVerified Boolean     @default(false)
  households    Household[] @relation("HouseholdOwner")
  consents      Consent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([authProvider, providerId])
}

model Household {
  id        String            @id @default(uuid())
  ownerId   String
  owner     User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  members   HouseholdMember[]
  notifications FamilyNotification[]
  activities    HouseholdActivity[]
  supportCases  SupportCase[]
  subscriptionRequests SubscriptionRequest[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([ownerId])
}

model HouseholdMember {
  id                    String                @id @default(uuid())
  householdId           String
  household             Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  firstName             String
  lastName              String
  birthDate             DateTime?
  relationship          HouseholdRelationship
  profileType           HouseholdProfileType @default(OTHER)
  schoolLevel           SchoolLevel?
  department            String?
  isHolder              Boolean               @default(false)
  isPayer               Boolean               @default(false)
  isLegalRepresentative Boolean               @default(false)
  subscriptions         Subscription[]
  subscriptionRequests  SubscriptionRequest[] @relation("SubscriptionRequestMember")
  payerRequests         SubscriptionRequest[] @relation("SubscriptionRequestPayer")
  notifications         FamilyNotification[]
  activities            HouseholdActivity[]
  profileDetail         MemberProfileDetail?
  supportCases          SupportCase[]
  navigoPass            NavigoPass?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([householdId])
}

model NavigoPass {
  id                  String                @id @default(uuid())
  householdMemberId   String                @unique
  householdMember     HouseholdMember       @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)
  navigoNumber        String                @unique
  productName         String
  supportType         NavigoPassSupportType @default(PHYSICAL)
  status              NavigoPassStatus      @default(IN_PROGRESS)
  supportSwitches     NavigoPassSupportSwitch[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([householdMemberId])
  @@index([supportType])
  @@index([status])
}

model NavigoPassSupportSwitch {
  id              String                @id @default(uuid())
  navigoPassId    String
  navigoPass      NavigoPass            @relation(fields: [navigoPassId], references: [id], onDelete: Cascade)
  previousSupport NavigoPassSupportType
  newSupport      NavigoPassSupportType
  createdAt       DateTime              @default(now())

  @@index([navigoPassId])
  @@index([createdAt])
}

model ProductOffer {
  id                 String                  @id @default(uuid())
  slug               String                  @unique
  name               String
  productType        ProductType
  shortDescription   String
  longDescription    String
  priceLabel         String
  durationLabel      String
  targetProfile      TargetProfile
  minAge             Int?
  maxAge             Int?
  isActive           Boolean                 @default(true)
  order              Int                     @default(0)
  benefits           OfferBenefit[]
  requiredDocuments  OfferRequiredDocument[]
  subscriptionRequests SubscriptionRequest[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([productType])
  @@index([targetProfile])
  @@index([isActive, order])
}

model OfferBenefit {
  id        String       @id @default(uuid())
  offerId   String
  offer     ProductOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  label     String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([offerId])
}

model OfferRequiredDocument {
  id           String       @id @default(uuid())
  offerId      String
  offer        ProductOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  documentType DocumentType
  label        String
  required     Boolean      @default(true)
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([offerId])
}

model SubscriptionRequest {
  id                         String                    @id @default(uuid())
  requestNumber              String?                   @unique
  flowType                   SubscriptionRequestFlow   @default(GENERIC)
  householdId                String
  household                  Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  memberId                   String
  member                     HouseholdMember           @relation("SubscriptionRequestMember", fields: [memberId], references: [id], onDelete: Cascade)
  offerId                    String
  offer                      ProductOffer              @relation(fields: [offerId], references: [id], onDelete: Restrict)
  payerMemberId              String?
  payerMember                HouseholdMember?          @relation("SubscriptionRequestPayer", fields: [payerMemberId], references: [id], onDelete: SetNull)
  status                     SubscriptionRequestStatus @default(WAITING_DOCUMENTS)
  autoRenewalEnabled         Boolean                   @default(false)
  renewalType                SubscriptionRenewalType?
  renewalStatus              SubscriptionRenewalStatus @default(DISABLED)
  renewalMonths              Int?
  renewalMonthsRemaining     Int?
  renewalNextDate            DateTime?
  renewalActivatedAt         DateTime?
  renewalCancelledAt         DateTime?
  intelligentDossierEnabled  Boolean                   @default(false)
  hasPreviousImagineR         Boolean?
  hasCustomerNumber           Boolean?
  customerNumber              String?
  infoCertificationAccepted   Boolean                   @default(false)
  holderAddressSameAsPayer    Boolean                   @default(true)
  payerBirthDate              DateTime?
  schoolZipOrCity             String?
  schoolName                  String?
  imagineRSchoolLevel         SchoolLevel?
  scholarshipStatus           ImagineRScholarshipStatus?
  forfaitStartDate            DateTime?
  validityStartDate           DateTime?
  validityEndDate             DateTime?
  deliveryMode                ImagineRDeliveryMode?
  baseAmountCents             Int?
  feeAmountCents              Int?
  totalAmountCents            Int?
  currency                    String                    @default("EUR")
  signatureInformationAccepted Boolean                  @default(false)
  signaturePayerAccepted      Boolean                   @default(false)
  signatureTermsAccepted      Boolean                   @default(false)
  signatureDocumentsAccepted  Boolean                   @default(false)
  signedAt                    DateTime?
  paymentSimulatedAt          DateTime?
  paymentConfirmedAt          DateTime?
  paymentCancelledAt          DateTime?
  stripeCheckoutSessionId     String?
  stripePaymentIntentId       String?
  submittedAt                 DateTime?
  reviewedAt                  DateTime?
  rejectionReason             String?
  addresses                  SubscriptionRequestAddress[]
  documents                  SubscriptionDocument[]
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  @@index([householdId])
  @@index([memberId])
  @@index([offerId])
  @@index([payerMemberId])
  @@index([flowType])
  @@index([status])
  @@index([renewalStatus])
  @@index([stripeCheckoutSessionId])
}

model SubscriptionRequestAddress {
  id                     String                         @id @default(uuid())
  subscriptionRequestId  String
  subscriptionRequest    SubscriptionRequest            @relation(fields: [subscriptionRequestId], references: [id], onDelete: Cascade)
  type                   SubscriptionRequestAddressType
  street                 String
  addressLine1           String?
  addressLine2           String?
  addressLine3           String?
  postalCode             String
  city                   String
  country                String                         @default("France")
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  @@unique([subscriptionRequestId, type])
  @@index([subscriptionRequestId])
}

model SubscriptionDocument {
  id                     String                     @id @default(uuid())
  subscriptionRequestId  String
  subscriptionRequest    SubscriptionRequest        @relation(fields: [subscriptionRequestId], references: [id], onDelete: Cascade)
  documentType           DocumentType
  label                  String
  status                 SubscriptionDocumentStatus @default(MISSING)
  rejectionReason        String?
  simulatedFileName      String?
  simulatedMimeType      String?
  simulatedSizeBytes     Int?
  simulatedPreviewDataUrl String?
  storedFilePath         String?
  uploadedAt             DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  @@index([subscriptionRequestId])
}

model Consent {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ConsentType
  accepted  Boolean
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

model Subscription {
  id               String                  @id @default(uuid())
  householdMemberId String
  householdMember  HouseholdMember         @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)
  productType      SubscriptionProductType
  productName      String
  status           SubscriptionStatus
  sourceRequestId  String?                 @unique
  nextActionLabel  String?
  recommendedProduct String?
  renewalDate      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([householdMemberId])
}

model FamilyNotification {
  id         String                     @id @default(uuid())
  householdId String
  household  Household                  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  memberId   String?
  member     HouseholdMember?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  type       FamilyNotificationType
  title      String
  message    String
  severity   FamilyNotificationSeverity
  read       Boolean                    @default(false)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  @@index([householdId])
  @@index([memberId])
}

model HouseholdActivity {
  id          String           @id @default(uuid())
  householdId String
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  memberId    String?
  member      HouseholdMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  label       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([householdId])
  @@index([memberId])
}

model MemberProfileDetail {
  id                String               @id @default(uuid())
  householdMemberId String               @unique
  householdMember  HouseholdMember      @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)
  householdRole    String
  overview         String
  supportNote      String
  accessibilityNote String?
  documents        String[]
  actions          MemberDetailAction[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model MemberDetailAction {
  id        String                    @id @default(uuid())
  detailId  String
  detail    MemberProfileDetail       @relation(fields: [detailId], references: [id], onDelete: Cascade)
  label     String
  href      String?
  action    String?
  variant   MemberDetailActionVariant
  order     Int                       @default(0)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([detailId])
}

model SupportCase {
  id               String            @id @default(uuid())
  householdId      String?
  household        Household?        @relation(fields: [householdId], references: [id], onDelete: SetNull)
  memberId         String?
  member           HouseholdMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  type             SupportCaseType
  status           SupportCaseStatus @default(OPEN)
  reason           String?
  chosenResolution SupportCaseResolution?
  finalChoice      SupportCaseFinalChoice?
  description      String?
  passNumberMasked String?
  foundLocation    String?
  foundDeskName    String?
  foundDeskAddress String?
  foundAt          DateTime?
  depositedAtDesk  Boolean?
  clientNotifiedAt DateTime?
  pickedUpAt       DateTime?
  finalChoiceAt    DateTime?
  pickupDeadlineAt DateTime?
  passDestroyedAt  DateTime?
  physicalPassReactivatedAt DateTime?
  digitalSupportRating Int?
  cancelledAt      DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([householdId])
  @@index([memberId])
}
