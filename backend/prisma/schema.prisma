generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  EMPLOYEE
  ADMIN
}

enum HouseholdRelationship {
  SELF
  CHILD
  RELATIVE
}

enum HouseholdProfileType {
  MANAGER
  YOUNG
  SENIOR
  OTHER
}

enum SchoolLevel {
  PRIMARY
  COLLEGE
  LYCEE
  HIGHER_EDUCATION
  OTHER
}

enum ConsentType {
  SERVICE_ALERTS
  MOBILITY_NEWS
  PARTNER_OFFERS
}

enum SubscriptionProductType {
  NAVIGO_ANNUAL
  IMAGINE_R
  NAVIGO_JUNIOR
  NAVIGO_SENIOR
  AMETHYSTE
  TST
  UNKNOWN
}

enum SubscriptionStatus {
  ACTIVE
  TO_RENEW
  RECOMMENDED
  PENDING_DOCUMENT
  BLOCKED
  LOST
  EXPIRED
}

enum FamilyNotificationType {
  RENEWAL
  OFFER_RECOMMENDATION
  SERVICE_INFO
  SUPPORT_UPDATE
}

enum FamilyNotificationSeverity {
  INFO
  WARNING
  SUCCESS
  DANGER
}

enum SupportCaseType {
  LOST_PASS
  FOUND_PASS
  DOCUMENT_REJECTED
  PAYMENT_BLOCKED
}

enum SupportCaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum MemberDetailActionVariant {
  PRIMARY
  SECONDARY
  GHOST
}

model User {
  id            String      @id @default(uuid())
  firstName     String      @default("")
  lastName      String      @default("")
  email         String      @unique
  phone         String      @default("")
  passwordHash  String      @default("")
  role          UserRole    @default(USER)
  phoneVerified Boolean     @default(false)
  emailVerified Boolean     @default(false)
  households    Household[] @relation("HouseholdOwner")
  consents      Consent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Household {
  id        String            @id @default(uuid())
  ownerId   String
  owner     User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  members   HouseholdMember[]
  notifications FamilyNotification[]
  activities    HouseholdActivity[]
  supportCases  SupportCase[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([ownerId])
}

model HouseholdMember {
  id                    String                @id @default(uuid())
  householdId           String
  household             Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  firstName             String
  lastName              String
  birthDate             DateTime?
  relationship          HouseholdRelationship
  profileType           HouseholdProfileType @default(OTHER)
  schoolLevel           SchoolLevel?
  department            String?
  isHolder              Boolean               @default(false)
  isPayer               Boolean               @default(false)
  isLegalRepresentative Boolean               @default(false)
  subscriptions         Subscription[]
  notifications         FamilyNotification[]
  activities            HouseholdActivity[]
  profileDetail         MemberProfileDetail?
  supportCases          SupportCase[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([householdId])
}

model Consent {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ConsentType
  accepted  Boolean
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

model Subscription {
  id               String                  @id @default(uuid())
  householdMemberId String
  householdMember  HouseholdMember         @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)
  productType      SubscriptionProductType
  productName      String
  status           SubscriptionStatus
  nextActionLabel  String?
  recommendedProduct String?
  renewalDate      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([householdMemberId])
}

model FamilyNotification {
  id         String                     @id @default(uuid())
  householdId String
  household  Household                  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  memberId   String?
  member     HouseholdMember?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  type       FamilyNotificationType
  title      String
  message    String
  severity   FamilyNotificationSeverity
  read       Boolean                    @default(false)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  @@index([householdId])
  @@index([memberId])
}

model HouseholdActivity {
  id          String           @id @default(uuid())
  householdId String
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  memberId    String?
  member      HouseholdMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  label       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([householdId])
  @@index([memberId])
}

model MemberProfileDetail {
  id                String               @id @default(uuid())
  householdMemberId String               @unique
  householdMember  HouseholdMember      @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)
  householdRole    String
  overview         String
  supportNote      String
  accessibilityNote String?
  documents        String[]
  actions          MemberDetailAction[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model MemberDetailAction {
  id        String                    @id @default(uuid())
  detailId  String
  detail    MemberProfileDetail       @relation(fields: [detailId], references: [id], onDelete: Cascade)
  label     String
  href      String?
  action    String?
  variant   MemberDetailActionVariant
  order     Int                       @default(0)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([detailId])
}

model SupportCase {
  id               String            @id @default(uuid())
  householdId      String?
  household        Household?        @relation(fields: [householdId], references: [id], onDelete: SetNull)
  memberId         String?
  member           HouseholdMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  type             SupportCaseType
  status           SupportCaseStatus @default(OPEN)
  description      String?
  passNumberMasked String?
  foundLocation    String?
  depositedAtDesk  Boolean?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([householdId])
  @@index([memberId])
}
